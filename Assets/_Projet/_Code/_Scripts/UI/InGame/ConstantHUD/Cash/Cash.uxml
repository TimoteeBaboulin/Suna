<engine:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:engine="UnityEngine.UIElements" xmlns:editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <engine:VisualElement name="Background" style="flex-grow: 0; width: auto; height: auto; flex-shrink: 1; bottom: 0; right: 0; position: absolute; flex-direction: row; justify-content: space-evenly; -unity-text-align: middle-left; font-size: 70%; margin-top: 20px; margin-right: 20px; margin-bottom: 20px; margin-left: 20px; align-items: center; align-content: flex-end; color: rgb(255, 255, 255);">
