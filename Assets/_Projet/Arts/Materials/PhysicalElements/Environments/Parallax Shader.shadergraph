{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "a2d45a1ed71b453db0d3425aed524b42",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "ParallaxMapping (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -889.0,
            "y": -546.9999389648438,
            "width": 248.0,
            "height": 422.0
        }
    },
    "m_Slots": [
        {
            "m_Id": "5c1939acb0294552afb2eacf4050e20c"
        },
        {
            "m_Id": "6dd47ec52eea439dbf7c9c5b3e0cce34"
        },
        {
            "m_Id": "f35bbd97b6cd45828bbe52cb411c9c99"
        },
        {
            "m_Id": "0ec2091e46f34df18114e11a0677c6f3"
        },
        {
            "m_Id": "e2cf8a8c3f4f41a78a1f43539259f9de"
        },
        {
            "m_Id": "22e6c409017b41daa53eb528807e22a9"
        },
        {
            "m_Id": "3d6b59d363c6403bb43ad621d568a2a8"
        },
        {
            "m_Id": "deab03a8618c46089a717cf31284945a"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": true,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "ParallaxMapping",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float Layers = lerp(Max_Layers, Min_Layers, max(dot(float3(0, 0, 1), ViewDir), 0.0));\n\nfloat layerDepth = 1.0 / Layers;\nfloat currentLayerDepth = 0.0;\n\nfloat2 P = ViewDir.xy * Height_Factor;\nfloat2 deltaCoord = P / Layers;\n\nfloat2 currentTexCoord = TexCoords;\nfloat currentDepth = Disp_Map.Sample(Sampler, currentTexCoord).x;\n\n[loop]\nfor(; currentLayerDepth < currentDepth; currentLayerDepth += layerDepth)\n{\n\tcurrentTexCoord -= deltaCoord;\n\tcurrentDepth = Disp_Map.Sample(Sampler, currentTexCoord).x;\n}\n\nfloat2 prevTexCoords = currentTexCoord + deltaCoord;\n\nfloat afterDepth = currentDepth - currentLayerDepth;\nfloat beforeDepth = Disp_Map.Sample(Sampler, prevTexCoords).r - currentLayerDepth + layerDepth;\n\nfloat weight = afterDepth / (afterDepth - beforeDepth);\nfloat2 finalTexCoord = lerp(prevTexCoords, currentTexCoord, weight);\n\nParallaxUV = finalTexCoord;"
}

