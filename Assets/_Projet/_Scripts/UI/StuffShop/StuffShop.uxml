                <engine:Button name="ButtonShield" icon-image="project://database/Assets/_Projet/Arts/HUD_General/SHOP/Bouclier.png?fileID=2800000&amp;guid=3df3912542f12904c82b219baa0c18a1&amp;type=3#Bouclier" class="shop_buy_slot_button" style="top: 770px; left: auto;" />
            </engine:VisualElement>
            <engine:VisualElement name="ColumnCenter" style="flex-grow: 0; position: absolute; height: 100%; width: 400px; align-self: center; align-items: center; left: auto;">
                <engine:Label text="Rifles" name="LabelRifle" class="shop_label_indicator" style="top: 20px;" />
