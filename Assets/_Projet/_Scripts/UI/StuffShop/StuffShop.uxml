                <engine:Label text="Handguns" name="LabelHandgun" class="shop_label_indicator" style="top: 495px;" />
                <engine:Button name="ButtonLP17" icon-image="project://database/Assets/_Projet/Arts/HUD_General/SHOP/Corpo_handgun.png?fileID=2800000&amp;guid=d5fe8ef4de6230d448688c38a35f0bb3&amp;type=3#Corpo_handgun" class="shop_buy_slot_button shop_buy_slot_weapon" style="top: 530px; left: auto;" />
                <engine:Button name="ButtonFakir" icon-image="project://database/Assets/_Projet/Arts/HUD_General/SHOP/native_handgun.png?fileID=2800000&amp;guid=b5f8d72d2af183946ac0e5381be60813&amp;type=3#native_handgun" class="shop_buy_slot_button shop_buy_slot_weapon" style="top: 770px; left: auto;" />
