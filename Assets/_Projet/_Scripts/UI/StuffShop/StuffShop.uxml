<engine:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:engine="UnityEngine.UIElements" xmlns:editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/_Projet/_Scripts/UI/StuffShop/shop-style.uss?fileID=7433441132597879392&amp;guid=738c7005ed4f6cc45aac3b5da323b218&amp;type=3#shop-style" />
    <engine:VisualElement name="Background" style="flex-grow: 1; background-color: rgba(0, 0, 0, 0.95); align-items: center; justify-content: center; -unity-font-definition: url(&quot;project://database/Assets/_Projet/Arts/Fonts/Nasalization%20Rg.otf?fileID=12800000&amp;guid=06393c2b6298fae42b401ef0082880d0&amp;type=3#Nasalization Rg&quot;);">
        <engine:VisualElement name="ShopMenu" style="flex-grow: 0; position: absolute; width: 1500px; height: 1000px; top: auto; left: auto; right: 10px; bottom: auto; flex-shrink: 0; background-color: rgba(64, 64, 64, 0.25); align-self: flex-end;">
            <engine:VisualElement name="ShopLines" picking-mode="Ignore" style="flex-grow: 1; position: absolute; background-image: url(&quot;project://database/Assets/_Projet/Arts/HUD_General/SHOP/Line_Contour.png?fileID=2800000&amp;guid=b6ed34adffa4dfd44a2d3d3bcdda38c5&amp;type=3#Line_Contour&quot;); width: 1469px; height: 978px; align-self: center; top: 50%; bottom: 50%; translate: 0 -50%;" />
            <engine:VisualElement name="ColumnLeft" style="flex-grow: 0; position: absolute; height: 100%; width: 400px; align-self: flex-start; align-items: center; left: 80px;">
                <engine:Label text="SMG" name="LabelSMG" class="shop_label_indicator" style="top: 20px;" />
