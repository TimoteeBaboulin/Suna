                <engine:Label text="Sniper" name="LabelSniper" class="shop_label_indicator" style="top: 495px;" />
                <engine:Button name="ButtonLaksya" icon-image="project://database/Assets/_Projet/Arts/HUD_General/SHOP/SNIPER.png?fileID=2800000&amp;guid=593c46e346b4ace45976f9f3a5901da7&amp;type=3#SNIPER" class="shop_buy_slot_button shop_buy_slot_weapon" style="top: 530px; left: auto;" />
